{
  "manifest_version": 3,
  "name": "VBDH Assistant - Trợ lý văn bản điều hành",
  "version": "2.2.0",
  "description": "Tổng hợp nội dung văn bản, trích xuất nhiệm vụ và quản lý phân công phòng ban từ hệ thống QLVBDH",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "webRequest",
    "tabs"
  ],
  "host_permissions": [
    "https://qlvbdh.danang.gov.vn/*",
    "https://tbklhoatien.danangsite.com.vn/*"
  ],
  "action": {
    "default_popup": "popup2.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://qlvbdh.danang.gov.vn/*",
        "https://tbklhoatien.danangsite.com.vn/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["chatbot.js"],
      "matches": [
        "https://qlvbdh.danang.gov.vn/*",
        "https://tbklhoatien.danangsite.com.vn/*"
      ]
    }
  ]
}
